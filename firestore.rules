rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── User profiles ────────────────────────────────────────────────────────
    // Block any write that includes a `password` field.
    // This is a defense-in-depth measure: even if a client bug reintroduces
    // a password write, the rule will reject it server-side.
    match /workspaces/{workspace}/users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && !('password' in request.resource.data);
    }

    // ─── Features ─────────────────────────────────────────────────────────────
    match /workspaces/{workspace}/features/{featureId} {
      allow read, write: if request.auth != null;
    }

    // ─── Config ───────────────────────────────────────────────────────────────
    match /workspaces/{workspace}/config/{configId} {
      allow read, write: if request.auth != null;
    }

    // ─── AI Training ──────────────────────────────────────────────────────────
    match /workspaces/{workspace}/ai-training/{entryId} {
      allow read, write: if request.auth != null;
    }

    // ─── Chat Sessions (Tepat AI conversation history) ────────────────────────
    // Each session has a userId field; we don't enforce per-user isolation here
    // because the app is single-workspace and admin can see all by design.
    // Filtering by userId happens client-side in subscribeToChatSessions.
    match /workspaces/{workspace}/chat-sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }
  }
}
